---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiloHero from "../../components/SiloHero.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Cta from "../../components/Cta.astro";
import SiloStyles from "../../components/SiloStyles.astro";
import InsuranceDisclaimer from "../../components/InsuranceDisclaimer.astro";

import Icon from "../../components/Icon.astro";
const facility = (await getEntry("facility", "golden-grove-recovery"))!.data;
const conditions = (await getCollection("mentalHealth")).sort((a, b) => a.data.name.localeCompare(b.data.name));

const title = `Dual-Diagnosis Treatment in ${facility.city}, ${facility.stateCode} | Golden Grove Recovery`;
const description = `Integrated treatment for substance use disorder and co-occurring depression, anxiety, PTSD, bipolar, and other mental health conditions. Kentucky Medicaid covered.`;

const jsonLd = { "@context": "https://schema.org", "@type": "MedicalWebPage", name: title, description };

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (p: string) => `${BASE}${p}`;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiloStyles />
  <div class="silo-body">
    <SiloHero
      eyebrow={`${facility.city}, ${facility.stateCode} · Dual Diagnosis`}
      title="Dual-diagnosis treatment for addiction and mental health"
      lede="Treating addiction without addressing co-occurring depression, anxiety, PTSD, or bipolar produces worse outcomes for both. Integrated dual-diagnosis treatment is typically covered by Kentucky Medicaid planss."
    />
    <Breadcrumbs trail={[
      { label: "Home", href: "/" },
      { label: "Co-Occurring Mental Health" },
    ]} />

    <section class="silo-section is-light">
      <div class="silo-container">
        <div class="silo-section-label">Verify Medicaid coverage</div>
        <h2>Integrated treatment is a unified Kentucky Medicaid benefit</h2>
        <p>
          Kentucky Medicaid administers behavioral health and SUD as one benefit. Psychiatric
          medication management, evidence-based therapy, and SUD care can all be billed and
          coordinated within the same episode at Golden Grove Recovery.
        </p>
        <InsuranceDisclaimer variant="pre-opening" />
      </div>
    </section>

    <section class="silo-section is-dust">
      <div class="silo-container">
        <div class="silo-section-label">Conditions we treat alongside SUD</div>
        <h2>Co-occurring conditions</h2>
        <div class="silo-grid">
          {conditions.map((c) => (
            <a class="silo-card silo-card-link" href={link(`/mental-health/${c.data.slug}`)}>
              <div class="silo-card-eyebrow">Dual Diagnosis</div>
              <h3>{c.data.name}</h3>
              <span class="silo-card-arrow">Treatment overview →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <Cta heading="Verify your coverage and start integrated treatment" />
  </div>
</BaseLayout>
