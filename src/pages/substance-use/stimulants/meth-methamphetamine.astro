---
import { getEntry } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import SiloStyles from "../../../components/SiloStyles.astro";
import SubstancePage from "../../../components/SubstancePage.astro";

const s = (await getEntry("substances", "meth-methamphetamine"))!.data;
const facility = (await getEntry("facility", "golden-grove-recovery"))!.data;

const title = `Methamphetamine Addiction Treatment in ${facility.city}, ${facility.stateCode} | Golden Grove Recovery`;
const description = `Evidence-based behavioral treatment, residential care, and integrated psychiatric support for meth addiction in Louisville, KY. Kentucky Medicaid covered.`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "MedicalWebPage",
    name: title,
    description,
    about: { "@type": "MedicalCondition", name: s.name, code: { "@type": "MedicalCode", codeValue: s.icd10[0], codingSystem: "ICD-10" } },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: s.faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiloStyles />
  <Breadcrumbs trail={[
    { label: "Home", href: "/" },
    { label: "Substance Use", href: "/substance-use" },
    { label: "Stimulants" },
    { label: "Methamphetamine" },
  ]} />
  <SubstancePage substanceSlug="meth-methamphetamine" />
</BaseLayout>
