---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiloHero from "../../components/SiloHero.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Cta from "../../components/Cta.astro";
import SiloStyles from "../../components/SiloStyles.astro";
import Icon from "../../components/Icon.astro";
import InsuranceDisclaimer from "../../components/InsuranceDisclaimer.astro";

const facility = (await getEntry("facility", "golden-grove-recovery"))!.data;
const mcos = (await getCollection("mcos")).sort((a, b) => a.data.name.localeCompare(b.data.name));

const title = `Verify Your Insurance Coverage | Golden Grove Recovery`;
const description = `Quickly verify your Kentucky Medicaid or commercial insurance coverage for addiction treatment. Free, confidential, no obligation.`;

const jsonLd = { "@context": "https://schema.org", "@type": "WebPage", name: title, description };

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (p: string) => `${BASE}${p}`;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiloStyles />
  <div class="silo-body">
    <SiloHero
      eyebrow="Admissions · Verify Insurance"
      title="Verify your insurance coverage"
      lede="Most patients are surprised by how much treatment is covered. Whether you have Kentucky Medicaid or commercial insurance, our admissions team verifies benefits in real time so you know exactly what's covered before you start."
    />
    <Breadcrumbs trail={[
      { label: "Home", href: "/" },
      { label: "Admissions", href: "/admissions" },
      { label: "Verify Insurance" },
    ]} />

    <section class="silo-section is-light">
      <div class="silo-container">
        <div class="silo-section-label">Kentucky Medicaid</div>
        <h2>Insurance plans we work with</h2>
        <div class="silo-grid">
          {mcos.map((m) => (
            <a class="silo-card silo-card-link" href={link(`/medicaid/${m.data.slug}`)}>
              <div class="silo-card-icon"><Icon name="shield-check" size={28} /></div>
              <div class="silo-card-eyebrow">Kentucky Medicaid</div>
              <h3>{m.data.shortName}</h3>
              <span class="silo-card-arrow">View {m.data.shortName} coverage →</span>
            </a>
          ))}
        </div>
        <InsuranceDisclaimer variant="both" />
      </div>
    </section>

    <section class="silo-section is-dust">
      <div class="silo-container">
        <div class="silo-section-label">Commercial insurance</div>
        <h2>Most major carriers accepted</h2>
        <p>{facility.insurance.commercialCarriers.map((c) => <span class="silo-pill">{c}</span>)}</p>
      </div>
    </section>

    <section class="silo-section is-light">
      <div class="silo-container silo-narrow">
        <div class="silo-section-label">How to verify</div>
        <h2>Three steps to a coverage answer</h2>
        <ol>
          <li><strong>Call <a href={`tel:${facility.phoneTel}`}>{facility.phone}</a></strong> — admissions answers 24/7.</li>
          <li>Have ready: insurance card (or member ID + plan name), patient's full legal name and date of birth, and the type of treatment you're seeking (detox, residential, PHP, IOP, outpatient, MAT).</li>
          <li>Most coverage answers come back same day — often within a few hours.</li>
        </ol>

        <h3>If you don't have insurance</h3>
        <p>You still have options. See <a href={link("/medicaid/no-insurance-options")}>no-insurance options</a> — including how to apply for Kentucky Medicaid (most adults qualify based on income alone), presumptive eligibility, sliding-scale providers, and state-funded programs.</p>
      </div>
    </section>

    <Cta heading="Call now to discuss your coverage"
         subhead={`Or email ${facility.email} with your member ID and we'll get back to you fast.`} />
  </div>
</BaseLayout>
