---
import { getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiloHero from "../../components/SiloHero.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Cta from "../../components/Cta.astro";
import SiloStyles from "../../components/SiloStyles.astro";
import Icon from "../../components/Icon.astro";

const facility = (await getEntry("facility", "golden-grove-recovery"))!.data;

const title = `The Admissions Process — Step by Step | Golden Grove Recovery`;
const description = `From first call through admission day — exactly what happens when you start treatment at Golden Grove Recovery in Louisville, KY.`;

const jsonLd = { "@context": "https://schema.org", "@type": "WebPage", name: title, description };

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (p: string) => `${BASE}${p}`;

const steps = [
  { eyebrow: "Day 1", icon: "phone" as const, title: "Initial call", body: `Call admissions at ${facility.phone}. We learn the basics, gather insurance information, and answer your initial questions.` },
  { eyebrow: "Day 1-2", icon: "shield-check" as const, title: "Insurance verification", body: "Our team verifies benefits with your Kentucky Medicaid plans or commercial carrier. We confirm what level of care is covered and what authorization (if any) is required." },
  { eyebrow: "Day 1-3", icon: "file-text" as const, title: "Clinical assessment", body: "A clinician conducts a confidential assessment — by phone, video, or in person. We use ASAM criteria to determine the appropriate level of care, plus identify any co-occurring mental health conditions." },
  { eyebrow: "Day 2-4", icon: "calendar" as const, title: "Authorization & scheduling", body: "With assessment results in hand, our team submits any required authorization. For Kentucky Medicaid detox and residential, this is typically same-day. We then schedule your admission date and confirm logistics." },
  { eyebrow: "Admission day", icon: "home" as const, title: "Welcome to Golden Grove", body: "Intake includes a medical evaluation, paperwork, orientation, and meeting your treatment team. If you're admitting to detox, symptom-based medication management starts as soon as withdrawal symptoms appear." },
  { eyebrow: "Throughout", icon: "users" as const, title: "Treatment", body: "Each level of care follows a structured schedule. MAT, individual therapy, group therapy, and integrated mental health care are all coordinated by your treatment team." },
  { eyebrow: "From day one", icon: "refresh" as const, title: "Discharge planning", body: "Discharge planning starts on day one, not the end. By the time you leave residential or PHP, you have a clear continuing-care plan: outpatient providers, MAT continuity, support groups, and recovery housing if needed." },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiloStyles />
  <div class="silo-body">
    <SiloHero
      eyebrow="Admissions · Process"
      title="The admissions process — step by step"
      lede="Most patients move from first call to admission within a few days. Patients in active withdrawal or crisis can often start the same day. Here's what each step looks like."
    />
    <Breadcrumbs trail={[
      { label: "Home", href: "/" },
      { label: "Admissions", href: "/admissions" },
      { label: "Process" },
    ]} />

    <section class="silo-section is-light">
      <div class="silo-container">
        <div class="silo-section-label">From first call to treatment</div>
        <h2>Seven stages</h2>
        <div class="silo-grid">
          {steps.map((s) => (
            <div class="silo-card">
              <div class="silo-card-icon"><Icon name={s.icon} size={28} /></div>
              <div class="silo-card-eyebrow">{s.eyebrow}</div>
              <h3>{s.title}</h3>
              <p>{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <Cta heading="Ready to start? Call admissions" />
  </div>
</BaseLayout>
