---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiloHero from "../../components/SiloHero.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Cta from "../../components/Cta.astro";
import SiloStyles from "../../components/SiloStyles.astro";
import InsuranceDisclaimer from "../../components/InsuranceDisclaimer.astro";

import Icon from "../../components/Icon.astro";
const facility = (await getEntry("facility", "golden-grove-recovery"))!.data;
const levels = (await getCollection("levelsOfCare"))
  .sort((a, b) => Number(b.data.asamCode) - Number(a.data.asamCode));

const title = `Levels of Care for Addiction Treatment in ${facility.city}, ${facility.stateCode} | Golden Grove Recovery`;
const description = "ASAM-aligned levels of care: medical detox, residential, PHP, IOP, and outpatient. Treatment matched to clinical need at Golden Grove Recovery in Louisville, KY.";

const jsonLd = { "@context": "https://schema.org", "@type": "MedicalWebPage", name: title, description };

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (p: string) => `${BASE}${p}`;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiloStyles />
  <div class="silo-body">
    <SiloHero
      eyebrow={`${facility.city}, ${facility.stateCode} · ASAM Continuum`}
      title="Levels of care for addiction treatment"
      lede="Kentucky Medicaid covers the clinical continuum of substance use treatment at Golden Grove Recovery — every level of intensity, from 24/7 medical detox to long-term outpatient. Treatment matched to clinical need."
    />
    <Breadcrumbs trail={[
      { label: "Home", href: "/" },
      { label: "Levels of Care" },
    ]} />

    <section class="silo-section is-light">
      <div class="silo-container">
        <div class="silo-section-label">All five levels</div>
        <h2>Treatment matched to clinical need</h2>
        <p>
          Most patients move through several levels of care during recovery — starting at higher
          intensity for stabilization and stepping down as they build the skills and support to
          maintain recovery in less structured settings.
        </p>

        <div class="silo-table-wrap">
          <table class="silo-table">
            <thead>
              <tr><th>Level</th><th>ASAM</th><th>Duration</th><th>Hours / week</th></tr>
            </thead>
            <tbody>
              {levels.map((l) => (
                <tr>
                  <td><a href={link(`/levels-of-care/${l.data.slug}`)}><strong>{l.data.shortName}</strong></a></td>
                  <td>{l.data.asamCode}</td>
                  <td>{l.data.typicalDuration}</td>
                  <td>{l.data.hoursPerWeek ?? "—"}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <InsuranceDisclaimer variant="pre-opening" />
      </div>
    </section>

    <section class="silo-section is-dust">
      <div class="silo-container">
        <div class="silo-section-label">Each level in detail</div>
        <h2>Pick your level of care</h2>
        <div class="silo-grid">
          {levels.map((l) => (
            <a class="silo-card silo-card-link" href={link(`/levels-of-care/${l.data.slug}`)}>
              <div class="silo-card-eyebrow">ASAM {l.data.asamCode}</div>
              <h3>{l.data.name}</h3>
              <p>{l.data.description.split(". ")[0]}.</p>
              <span class="silo-card-arrow">Read more →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="silo-section is-light">
      <div class="silo-container silo-narrow">
        <div class="silo-section-label">Kentucky Medicaid coverage</div>
        <h2>Coverage by level of care</h2>
        <ul>
          <li><a href={link("/medicaid/medicaid-detox-coverage")}>Detox coverage</a></li>
          <li><a href={link("/medicaid/medicaid-residential-coverage")}>Residential coverage</a></li>
          <li><a href={link("/medicaid/medicaid-php-iop-coverage")}>PHP / IOP coverage</a></li>
          <li><a href={link("/medicaid/medicaid-outpatient-coverage")}>Outpatient coverage</a></li>
          <li><a href={link("/medicaid/medicaid-mat-coverage")}>MAT coverage</a></li>
        </ul>
      </div>
    </section>

    <Cta heading="Find the right level of care for you" />
  </div>
</BaseLayout>
