---
import { getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import SiloStyles from "../../components/SiloStyles.astro";
import LevelOfCarePage from "../../components/LevelOfCarePage.astro";

const l = (await getEntry("levelsOfCare", "partial-hospitalization-php"))!.data;
const facility = (await getEntry("facility", "golden-grove-recovery"))!.data;

const title = `Partial Hospitalization Program (PHP) in ${facility.city}, ${facility.stateCode} | Golden Grove Recovery`;
const description = "Daytime structured PHP (ASAM 2.5) for substance use disorder — 5-6 days/week of intensive programming while you live at home. Kentucky Medicaid covered.";

const jsonLd = { "@context": "https://schema.org", "@type": "MedicalWebPage", name: title, description };
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiloStyles />
  <Breadcrumbs trail={[
    { label: "Home", href: "/" },
    { label: "Levels of Care", href: "/levels-of-care" },
    { label: l.shortName },
  ]} />
  <LevelOfCarePage slug="partial-hospitalization-php" />
</BaseLayout>
