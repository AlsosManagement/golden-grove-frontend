---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiloHero from "../../components/SiloHero.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Cta from "../../components/Cta.astro";
import SiloStyles from "../../components/SiloStyles.astro";
import InsuranceDisclaimer from "../../components/InsuranceDisclaimer.astro";

import Icon from "../../components/Icon.astro";
const facility = (await getEntry("facility", "golden-grove-recovery"))!.data;
const locations = (await getCollection("locations")).sort((a, b) => a.data.name.localeCompare(b.data.name));

const title = `Service Areas in Greater ${facility.city}, ${facility.stateCode} | Golden Grove Recovery`;
const description = `Golden Grove Recovery serves Louisville and Greater Jefferson County, KY — including Jeffersontown and St. Matthews — with Kentucky Medicaid-covered addiction treatment.`;

const jsonLd = { "@context": "https://schema.org", "@type": "MedicalWebPage", name: title, description };

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (p: string) => `${BASE}${p}`;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiloStyles />
  <div class="silo-body">
    <SiloHero
      eyebrow={`${facility.city}, ${facility.stateCode} · Service Areas`}
      title={`Drug & alcohol rehab serving Greater ${facility.city}`}
      lede={`Golden Grove Recovery is located at ${facility.address.street}, ${facility.address.city}, ${facility.address.state} — serving Jefferson County and surrounding Kentucky communities with Medicaid-covered addiction treatment.`}
    />
    <Breadcrumbs trail={[
      { label: "Home", href: "/" },
      { label: "Service Areas" },
    ]} />

    <section class="silo-section is-light">
      <div class="silo-container">
        <div class="silo-section-label">Areas we serve</div>
        <h2>Communities in Greater {facility.city}</h2>
        <div class="silo-grid">
          {locations.map((l) => (
            <a class="silo-card silo-card-link" href={link(`/locations/${l.data.slug}`)}>
              <div class="silo-card-eyebrow">{l.data.type === "city" ? "City" : l.data.type === "neighborhood" ? "Neighborhood" : "Region"}</div>
              <h3>{l.data.name}, {l.data.stateCode}</h3>
              {l.data.distanceFromFacility && <p>{l.data.distanceFromFacility}</p>}
              <span class="silo-card-arrow">Coverage from {l.data.name} →</span>
            </a>
          ))}
        </div>

        <InsuranceDisclaimer variant="pre-opening" />
      </div>
    </section>

    <section class="silo-section is-dust">
      <div class="silo-container silo-narrow">
        <div class="silo-section-label">Kentucky residents only</div>
        <h2>Indiana residents</h2>
        <p>
          Indiana Medicaid does not cover treatment at Kentucky facilities. If you're an Indiana
          resident seeking treatment, our sister facility — <strong>Jasper Grove Recovery</strong>
          in Indiana — is the right fit. Our admissions team can help route you appropriately.
        </p>
      </div>
    </section>

    <Cta heading="Verify your coverage and start treatment" />
  </div>
</BaseLayout>
