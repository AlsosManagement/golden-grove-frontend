---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiloHero from "../../components/SiloHero.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Cta from "../../components/Cta.astro";
import SiloStyles from "../../components/SiloStyles.astro";
import InsuranceDisclaimer from "../../components/InsuranceDisclaimer.astro";

import Icon from "../../components/Icon.astro";
const php = (await getEntry("levelsOfCare", "partial-hospitalization-php"))!.data;
const iop = (await getEntry("levelsOfCare", "intensive-outpatient-iop"))!.data;
const mcos = (await getCollection("mcos")).sort((a, b) => a.data.name.localeCompare(b.data.name));

const title = "Does Kentucky Medicaid Cover PHP & IOP? | Golden Grove Recovery";
const description = "Kentucky Medicaid covers Partial Hospitalization (ASAM 2.5) and Intensive Outpatient (ASAM 2.1) for SUD. Coverage details, comparison, and how to verify by Medicaid plan.";

const faqs = [
  { q: "Does Kentucky Medicaid cover PHP and IOP?", a: "Yes. Kentucky Medicaid plans typically cover Partial Hospitalization (ASAM 2.5) and Intensive Outpatient (ASAM 2.1) when medically necessary. Authorization is typically handled through notification and concurrent review." },
  { q: "What's the difference between PHP and IOP?", a: "PHP is more intensive — typically 5-6 days per week with 6-8 hour daily sessions (20-30+ hours/week). IOP is 3-5 days per week with shorter sessions (9-19 hours/week), allowing patients to maintain work or school." },
  { q: "Can I start at PHP or IOP without going through residential?", a: "Yes. Many patients start at PHP or IOP directly when residential isn't clinically necessary. ASAM criteria determine the right starting level." },
  { q: "Does Medicaid cover MAT during PHP and IOP?", a: "Yes. MAT is integrated into PHP and IOP when clinically indicated and is a covered Medicaid pharmacy benefit." },
];

const jsonLd = [
  { "@context": "https://schema.org", "@type": "MedicalWebPage", name: title, description },
  { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) },
];

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (p: string) => `${BASE}${p}`;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiloStyles />
  <div class="silo-body">
    <SiloHero
      eyebrow="Kentucky Medicaid · PHP & IOP Coverage"
      title="Does Kentucky Medicaid cover PHP and IOP?"
      lede="Yes. Kentucky Medicaid plans typically cover Partial Hospitalization (PHP, ASAM 2.5) and Intensive Outpatient (IOP, ASAM 2.1) when medically necessary. Use as step-down from residential or step-up from outpatient."
    />
    <Breadcrumbs trail={[
      { label: "Home", href: "/" },
      { label: "Kentucky Medicaid", href: "/medicaid" },
      { label: "PHP & IOP Coverage" },
    ]} />

    <section class="silo-section is-light">
      <div class="silo-container">
        <div class="silo-section-label">Pick your plan</div>
        <h2>PHP and IOP coverage by Kentucky Medicaid plan</h2>
        <div class="silo-grid">
          {mcos.map((m) => (
            <a class="silo-card silo-card-link" href={link(`/medicaid/${m.data.slug}`)}>
              <div class="silo-card-icon"><Icon name="shield-check" size={28} /></div>
              <div class="silo-card-eyebrow">Kentucky Medicaid</div>
              <h3>{m.data.shortName}</h3>
              <span class="silo-card-arrow">View {m.data.shortName} coverage →</span>
            </a>
          ))}
        </div>
        <InsuranceDisclaimer variant="medicaid" />
      </div>
    </section>

    <section class="silo-section is-dust">
      <div class="silo-container">
        <div class="silo-section-label">PHP vs IOP at a glance</h2>
        <h2>How they compare</h2>
        <div class="silo-table-wrap">
          <table class="silo-table">
            <thead><tr><th></th><th>PHP (ASAM 2.5)</th><th>IOP (ASAM 2.1)</th></tr></thead>
            <tbody>
              <tr><td>Hours/week</td><td>20-30+</td><td>9-19</td></tr>
              <tr><td>Days/week</td><td>5-6</td><td>3-5</td></tr>
              <tr><td>Typical duration</td><td>2-6 weeks</td><td>8-12 weeks</td></tr>
              <tr><td>Work or school</td><td>Generally not</td><td>Yes (evening tracks)</td></tr>
              <tr><td>Best as step-down from</td><td>Residential</td><td>PHP or residential</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="silo-section is-light">
      <div class="silo-container silo-narrow">
        <div class="silo-section-label">Partial Hospitalization (PHP)</div>
        <h2>{php.name}</h2>
        <p>{php.description}</p>
        <p><strong>Hours:</strong> {php.hoursPerWeek} · <strong>Duration:</strong> {php.typicalDuration}</p>

        <h3 style="margin-top: 32px;">Intensive Outpatient (IOP)</h3>
        <h2 style="margin-top: 4px;">{iop.name}</h2>
        <p>{iop.description}</p>
        <p><strong>Hours:</strong> {iop.hoursPerWeek} · <strong>Duration:</strong> {iop.typicalDuration}</p>
      </div>
    </section>

    <Cta heading="Talk to our admissions team about PHP / IOP" />

    <section class="silo-section is-dust">
      <div class="silo-container silo-narrow">
        <div class="silo-section-label">FAQ</div>
        <h2>Frequently asked questions</h2>
        <div class="silo-faq">
          {faqs.map((f) => (
            <details>
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
