---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiloHero from "../../components/SiloHero.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Cta from "../../components/Cta.astro";
import SiloStyles from "../../components/SiloStyles.astro";
import InsuranceDisclaimer from "../../components/InsuranceDisclaimer.astro";

import Icon from "../../components/Icon.astro";
const residential = (await getEntry("levelsOfCare", "residential-inpatient"))!.data;
const mcos = (await getCollection("mcos")).sort((a, b) => a.data.name.localeCompare(b.data.name));

const title = "Does Kentucky Medicaid Cover Residential Rehab? | Golden Grove Recovery";
const description = "Kentucky Medicaid covers residential SUD treatment (ASAM 3.1, 3.3, 3.5) under the state's 1115 waiver. Coverage details, IMD exclusion explanation, and Medicaid plan-by-Medicaid plan breakdown.";

const faqs = [
  { q: "Does Kentucky Medicaid cover residential rehab?", a: "Yes. Kentucky Medicaid plans typically cover residential SUD treatment at ASAM 3.1, 3.3, and 3.5 based on medical-necessity determination using ASAM criteria." },
  { q: "What is the IMD exclusion and does it affect me?", a: "The Institution for Mental Disease (IMD) exclusion historically blocked Medicaid from paying for residential SUD treatment in facilities larger than 16 beds. Kentucky's 1115 demonstration waiver lifts this restriction." },
  { q: "How long will Medicaid pay for residential treatment?", a: "Coverage continues as long as residential level of care remains medically necessary, determined by ASAM criteria and concurrent clinical review. Typical residential stays run 21-28 days." },
  { q: "Does residential coverage include MAT?", a: "Yes. MAT (Suboxone, Subutex, methadone, Vivitrol, naltrexone) is integrated into residential treatment when clinically indicated, and is covered." },
];

const jsonLd = [
  { "@context": "https://schema.org", "@type": "MedicalWebPage", name: title, description },
  { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) },
];

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (p: string) => `${BASE}${p}`;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiloStyles />
  <div class="silo-body">
    <SiloHero
      eyebrow="Kentucky Medicaid · Residential Coverage"
      title="Does Kentucky Medicaid cover residential rehab?"
      lede="Yes. Kentucky's 1115 demonstration waiver lifts the historic IMD exclusion for SUD — meaning Medicaid pays for residential rehab at full-size licensed facilities, not only at small (≤16 bed) programs."
    />
    <Breadcrumbs trail={[
      { label: "Home", href: "/" },
      { label: "Kentucky Medicaid", href: "/medicaid" },
      { label: "Residential Coverage" },
    ]} />

    <section class="silo-section is-light">
      <div class="silo-container">
        <div class="silo-section-label">Pick your plan</div>
        <h2>Kentucky Medicaid plans typically cover residential treatment</h2>
        <div class="silo-grid">
          {mcos.map((m) => (
            <a class="silo-card silo-card-link" href={link(`/medicaid/${m.data.slug}`)}>
              <div class="silo-card-icon"><Icon name="shield-check" size={28} /></div>
              <div class="silo-card-eyebrow">Kentucky Medicaid</div>
              <h3>{m.data.shortName}</h3>
              <span class="silo-card-arrow">View {m.data.shortName} residential coverage →</span>
            </a>
          ))}
        </div>
        <InsuranceDisclaimer variant="medicaid" />
      </div>
    </section>

    <section class="silo-section is-dust">
      <div class="silo-container silo-narrow">
        <div class="silo-section-label">What residential covers</div>
        <h2>The standard of care for severe SUD</h2>
        <p>{residential.description}</p>
        <p><strong>Typical duration:</strong> {residential.typicalDuration} · <strong>Setting:</strong> {residential.hoursPerWeek}</p>

        <h3>The IMD exclusion and Kentucky's 1115 waiver</h3>
        <p>{residential.imdExclusionNote}</p>
        <p>In practical terms: a Kentucky Medicaid member with severe SUD can be admitted to Golden Grove Recovery (or any other licensed Kentucky residential SUD facility) and have their stay paid for by Medicaid — something that is not possible in many states.</p>
      </div>
    </section>

    <section class="silo-section is-light">
      <div class="silo-container">
        <div class="silo-section-label">Treatment continuum</div>
        <h2>What comes before and after residential</h2>
        <div class="silo-grid">
          <a class="silo-card silo-card-link" href={link("/medicaid/medicaid-detox-coverage")}>
            <div class="silo-card-eyebrow">Step in</div>
            <h3>Detox first if needed</h3>
            <span class="silo-card-arrow">Detox coverage →</span>
          </a>
          <a class="silo-card silo-card-link" href={link("/medicaid/medicaid-php-iop-coverage")}>
            <div class="silo-card-eyebrow">Step down</div>
            <h3>PHP and IOP</h3>
            <span class="silo-card-arrow">PHP / IOP coverage →</span>
          </a>
          <a class="silo-card silo-card-link" href={link("/medicaid/medicaid-mat-coverage")}>
            <div class="silo-card-eyebrow">Throughout</div>
            <h3>MAT continues</h3>
            <span class="silo-card-arrow">MAT coverage →</span>
          </a>
        </div>
      </div>
    </section>

    <Cta heading="Talk to our admissions team about residential" />

    <section class="silo-section is-dust">
      <div class="silo-container silo-narrow">
        <div class="silo-section-label">FAQ</div>
        <h2>Frequently asked questions</h2>
        <div class="silo-faq">
          {faqs.map((f) => (
            <details>
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
