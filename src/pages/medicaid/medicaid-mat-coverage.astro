---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiloHero from "../../components/SiloHero.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Cta from "../../components/Cta.astro";
import SiloStyles from "../../components/SiloStyles.astro";
import InsuranceDisclaimer from "../../components/InsuranceDisclaimer.astro";

import Icon from "../../components/Icon.astro";
const mcos = (await getCollection("mcos")).sort((a, b) => a.data.name.localeCompare(b.data.name));

const title = "Does Kentucky Medicaid Cover Suboxone, Methadone, & MAT? | Golden Grove Recovery";
const description = "Kentucky Medicaid covers Suboxone, Subutex, methadone, Vivitrol, and naltrexone for opioid and alcohol use disorder. Pharmacy benefits and authorization details by Medicaid plan.";

const faqs = [
  { q: "Does Kentucky Medicaid cover Suboxone?", a: "Yes. Kentucky Medicaid plans typically cover Suboxone for opioid use disorder. Specific formulations may require pharmacy prior authorization depending on the Medicaid plan's preferred drug list." },
  { q: "Does Kentucky Medicaid cover methadone?", a: "Yes. Methadone for OUD is a covered Kentucky Medicaid benefit, but it can only be dispensed at federally licensed opioid treatment programs (OTPs)." },
  { q: "Does Kentucky Medicaid cover Vivitrol?", a: "Yes. Vivitrol (extended-release naltrexone) is typically covered by Kentucky Medicaid plans for OUD and alcohol use disorder. Vivitrol requires patients to be opioid-free for 7-14 days before the first injection." },
  { q: "Can I get MAT during pregnancy on Kentucky Medicaid?", a: "Yes. Subutex (buprenorphine alone, without naloxone) is the standard MAT for pregnant members with OUD, and is typically covered by Kentucky Medicaid plans." },
  { q: "Are MAT prescriptions limited or capped on Medicaid?", a: "No. MAT is a long-term treatment for OUD and AUD, and Medicaid does not impose arbitrary duration caps." },
];

const jsonLd = [
  { "@context": "https://schema.org", "@type": "MedicalWebPage", name: title, description },
  { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) },
];

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (p: string) => `${BASE}${p}`;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiloStyles />
  <div class="silo-body">
    <SiloHero
      eyebrow="Kentucky Medicaid · MAT Coverage"
      title="Does Kentucky Medicaid cover Suboxone, methadone, and MAT?"
      lede="Yes. Kentucky Medicaid plans typically cover Medication-Assisted Treatment for opioid use disorder and alcohol use disorder. Suboxone, Subutex, methadone, Vivitrol, and naltrexone are all on the formulary."
    />
    <Breadcrumbs trail={[
      { label: "Home", href: "/" },
      { label: "Kentucky Medicaid", href: "/medicaid" },
      { label: "MAT Coverage" },
    ]} />

    <section class="silo-section is-light">
      <div class="silo-container">
        <div class="silo-section-label">Pick your plan</div>
        <h2>Kentucky Medicaid plans typically cover MAT</h2>
        <div class="silo-grid">
          {mcos.map((m) => (
            <a class="silo-card silo-card-link" href={link(`/medicaid/${m.data.slug}`)}>
              <div class="silo-card-icon"><Icon name="shield-check" size={28} /></div>
              <div class="silo-card-eyebrow">Kentucky Medicaid</div>
              <h3>{m.data.shortName}</h3>
              <span class="silo-card-arrow">View {m.data.shortName} MAT coverage →</span>
            </a>
          ))}
        </div>
        <InsuranceDisclaimer variant="medicaid" />
      </div>
    </section>

    <section class="silo-section is-dust">
      <div class="silo-container">
        <div class="silo-section-label">Medications on Kentucky Medicaid formulary</div>
        <h2>MAT medications covered</h2>
        <div class="silo-table-wrap">
          <table class="silo-table">
            <thead><tr><th>Medication</th><th>Used For</th><th>Setting</th></tr></thead>
            <tbody>
              <tr><td><strong>Suboxone</strong> (buprenorphine + naloxone)</td><td>OUD</td><td>Office-based</td></tr>
              <tr><td><strong>Subutex</strong> (buprenorphine alone)</td><td>OUD — pregnancy standard</td><td>Office-based</td></tr>
              <tr><td><strong>Methadone</strong></td><td>OUD</td><td>Licensed OTP only</td></tr>
              <tr><td><strong>Vivitrol</strong> (extended-release naltrexone)</td><td>OUD and AUD</td><td>Office-based monthly injection</td></tr>
              <tr><td><strong>Oral naltrexone</strong></td><td>OUD and AUD</td><td>Pharmacy</td></tr>
              <tr><td><strong>Acamprosate</strong></td><td>AUD</td><td>Pharmacy</td></tr>
              <tr><td><strong>Disulfiram</strong></td><td>AUD</td><td>Pharmacy</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="silo-section is-light">
      <div class="silo-container silo-narrow">
        <div class="silo-section-label">MAT in pregnancy</div>
        <h2>Subutex for pregnant Medicaid members</h2>
        <p>
          Pregnant members with opioid use disorder benefit from Subutex (buprenorphine alone,
          without naloxone) or methadone delivered through an OTP. Both are covered by all six
          Kentucky Medicaid plans and are the clinical standard of care during pregnancy.
        </p>

        <h3>MAT across the treatment continuum</h3>
        <p>
          MAT typically starts during <a href={link("/medicaid/medicaid-detox-coverage")}>detox</a>
          and continues through <a href={link("/medicaid/medicaid-residential-coverage")}>residential</a>,
          <a href={link("/medicaid/medicaid-php-iop-coverage")}>PHP / IOP</a>, and indefinitely at
          the <a href={link("/medicaid/medicaid-outpatient-coverage")}>outpatient</a> level.
        </p>
      </div>
    </section>

    <Cta heading="Talk to our admissions team about MAT" />

    <section class="silo-section is-dust">
      <div class="silo-container silo-narrow">
        <div class="silo-section-label">FAQ</div>
        <h2>Frequently asked questions</h2>
        <div class="silo-faq">
          {faqs.map((f) => (
            <details>
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
