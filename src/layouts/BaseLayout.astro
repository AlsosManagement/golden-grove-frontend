---
import Nav from "../components/Nav.jsx";
import Footer from "../components/Footer.jsx";
import { SITE } from "../data.js";

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: Record<string, any> | Record<string, any>[];
}

const {
  title,
  description,
  canonical,
  ogImage = "/cherry-blossom.png",
  noindex = false,
  jsonLd,
} = Astro.props as Props;

const BASE = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const assetPath = (p: string) =>
  p.startsWith("http") ? p : `${BASE}${p.replace(/^\//, "")}`;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = ogImage.startsWith("http")
  ? ogImage
  : new URL(assetPath(ogImage), Astro.site).toString();
const jsonLdArray = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={assetPath("favicon.svg")} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content={SITE.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap"
    />

    {jsonLdArray.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { width: 100%; min-height: 100vh; overflow-x: hidden; }
      html { scroll-behavior: smooth; }
      body { font-family: 'Montserrat', sans-serif; background: #FAF7F2; color: #1A1A1A; }
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: #EFE2C8; }
      ::-webkit-scrollbar-thumb { background: #8C6934; border-radius: 3px; }

      /* Pulsing CTA — GPU-accelerated, no layout cost. Disabled for users with
         reduced-motion preference. */
      @keyframes gg-cta-pulse {
        0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(242, 209, 125, 0.55); }
        50%      { transform: scale(1.035); box-shadow: 0 0 0 14px rgba(242, 209, 125, 0); }
      }
      .gg-btn-pulse {
        animation: gg-cta-pulse 2.4s ease-in-out infinite;
        will-change: transform, box-shadow;
      }
      @media (prefers-reduced-motion: reduce) {
        .gg-btn-pulse { animation: none; }
      }

      /* Compact phone-icon CTA in the fixed nav on mobile. The desktop nav
         shows the full "Call (xxx) xxx-xxxx" button; the mobile version
         shows just a phone glyph + "Call" text. Both versions visible so
         the call-to-action is always one tap away. */
      /* Single adaptive Call button in the nav.
         Always visible across every viewport. Phone icon + adaptive text:
           ≥1200px: "Call (502) 610-4829"     (full phone number)
           <1200px: "Call"                    (compact, icon supplies context)
         Padding tightens slightly on phones. Specificity is one class
         higher than .gg-btn so the cascade can't override display. */
      a.gg-btn.nav-call {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 8px 18px;
        font-size: 12px;
        border-radius: 6px;
        flex-shrink: 0;
      }
      .nav-call-icon { flex-shrink: 0; }
      .nav-call-text-full { display: inline; }
      .nav-call-text-short { display: none; }
      @media (max-width: 1199px) {
        .nav-call-text-full { display: none; }
        .nav-call-text-short { display: inline; }
        a.gg-btn.nav-call { padding: 8px 14px; }
      }

      /* Two SVG wordmark variants for brand consistency at every viewport.
         Full ("Golden Grove Recovery") is ~440px wide at 28px height — only
         fits on wide desktops. Compact ("Golden Grove") drops the "Recovery"
         portion via a tighter viewBox; renders ~140px wide at 26px height
         and fits comfortably on phones + narrow desktops. */
      .nav-wordmark-compact-svg { display: none; align-items: center; }
      @media (max-width: 1199px) {
        .nav-wordmark-svg { display: none !important; }
        .nav-wordmark-compact-svg { display: inline-flex; }
      }

      /* Site-wide nav, footer, button styles. Previously these lived only inside the
         React <GlobalStyles> component (src/components/shared.jsx), which is rendered
         only on the original 12 React pages. On Astro silo pages, the Nav React island
         mounted but its CSS classes were never injected — so the hamburger and desktop
         nav were both visible at the same time, the mobile breakpoint never fired, and
         nav links rendered as default <a> tags. Lifting them here so every page —
         React-island or pure Astro — renders the nav consistently. */
      .gg-btn {
        padding: 14px 36px; border-radius: 8px; border: 2px solid transparent;
        font-family: inherit; font-weight: 600; font-size: 14px;
        cursor: pointer; transition: all 0.25s; display: inline-block;
        text-decoration: none; text-align: center;
      }
      .gg-btn-primary { background: #461F01; color: #FFFFFF; border-color: #461F01; }
      .gg-btn-primary:hover { background: #8C6934; border-color: #8C6934; color: #FFFFFF; }
      .gg-btn-secondary { background: transparent; color: #FFFFFF; border-color: rgba(255,255,255,0.5); }
      .gg-btn-secondary:hover { background: #FFFFFF; color: #461F01; border-color: #FFFFFF; }
      .gg-btn-light { background: #FFFFFF; color: #461F01; border-color: #FFFFFF; }
      .gg-btn-light:hover { background: #EFE2C8; border-color: #EFE2C8; }
      .gg-btn-outline { background: transparent; color: #461F01; border-color: #461F01; }
      .gg-btn-outline:hover { background: #461F01; color: #FFFFFF; }

      .nav-link {
        padding: 8px 16px; color: #461F01; font-size: 13px; font-weight: 500;
        text-decoration: none; border-radius: 6px; transition: all 0.2s;
        letter-spacing: 0.01em;
      }
      .nav-link:hover { background: #EFE2C8; color: #8C6934; }

      .site-nav { height: 64px; padding: 0 24px; }
      .nav-wordmark svg { height: 44px; transition: height 0.2s; }
      .hamburger { display: none; }

      @media (max-width: 768px) {
        .desktop-only { display: none !important; }
        .hamburger { display: flex !important; }
        .site-nav { height: 56px !important; padding: 0 12px !important; }
        .nav-wordmark svg { height: 28px !important; }
        .mobile-menu { top: 56px !important; }

        .site-footer { padding: 32px 16px 0 !important; }
        .footer-wordmark svg { height: 28px !important; }
        .footer-wordmark { margin-bottom: 20px !important; }
        .footer-grid { grid-template-columns: 1fr 1fr !important; gap: 20px !important; }
        .footer-grid .footer-col-title { font-size: 11px !important; margin-bottom: 10px !important; }
        .footer-grid a, .footer-grid span, .footer-grid p { font-size: 12px !important; }
        .footer-grid .footer-contact-block p { font-size: 12px !important; line-height: 1.5 !important; margin-bottom: 8px !important; }
        .footer-bottom-bar { padding: 12px 16px !important; }
        .footer-bottom-inner { flex-direction: column !important; text-align: center !important; gap: 8px !important; }
        .footer-bottom-inner div { font-size: 11px !important; }
        .footer-bottom-inner span { font-size: 11px !important; }
      }
      @media (max-width: 480px) {
        .nav-wordmark svg { height: 22px !important; }
        .footer-wordmark svg { height: 22px !important; }
        .footer-grid { grid-template-columns: 1fr !important; }
      }
      @media (min-width: 769px) {
        .hamburger { display: none !important; }
      }
    </style>
  </head>

  <body>
    <Nav client:load />

    <main>
      <slot />
    </main>

    <Footer />

    <!-- Further (talkfurther) widget loader -->
    <script is:inline>
      (function () {
        var a = document.createElement("script");
        var b = document.getElementsByTagName("script")[0];
        a.type = "text/javascript";
        a.src = ('https:' == document.location.protocol ? 'https://' : 'http://') + "js.talkfurther.com/talkfurther_init.min.js";
        a.async = true;
        b.parentNode.insertBefore(a, b);
      })();
    </script>
  </body>
</html>
