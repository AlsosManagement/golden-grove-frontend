---
import { getCollection, getEntry } from "astro:content";
import SiloHero from "./SiloHero.astro";
import Breadcrumbs, { type Crumb } from "./Breadcrumbs.astro";
import Cta from "./Cta.astro";
import InsuranceDisclaimer from "./InsuranceDisclaimer.astro";
import Icon from "./Icon.astro";

export interface Props {
  slug: string;
  trail: Crumb[];
}

const { slug, trail } = Astro.props as Props;
const entry = await getEntry("mentalHealth", slug);
if (!entry) throw new Error(`Mental health entry not found: ${slug}`);
const m = entry.data;
const facility = (await getEntry("facility", "golden-grove-recovery"))!.data;
const mcos = (await getCollection("mcos")).sort((a, b) => a.data.name.localeCompare(b.data.name));
const others = (await getCollection("mentalHealth"))
  .filter((e) => e.data.slug !== m.slug)
  .sort((a, b) => a.data.name.localeCompare(b.data.name));

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (p: string) => `${BASE}${p}`;
---

<div class="silo-body">
  <SiloHero
    eyebrow={`${facility.city}, ${facility.stateCode} · Dual Diagnosis`}
    title={`${m.name} treatment in ${facility.city}, ${facility.stateCode}`}
    lede="Integrated dual-diagnosis treatment delivers better outcomes than treating one condition and deferring the other. Covered by most insurances."
  />
  <Breadcrumbs trail={trail} />

  <section class="silo-section is-light">
    <div class="silo-container">
      <div class="silo-section-label">Kentucky Medicaid coverage</div>
      <h2>Integrated treatment is typically covered by Kentucky Medicaid plans</h2>
      <p>
        Kentucky Medicaid administers behavioral health and substance use disorder services as a
        unified benefit. Psychiatric medication management, therapy, and SUD treatment can all be
        billed and coordinated within the same episode of care.
      </p>

      <div class="silo-grid">
        {mcos.map((mco) => (
          <a class="silo-card silo-card-link" href={link(`/medicaid/${mco.data.slug}`)}>
            <div class="silo-card-eyebrow">Kentucky Medicaid</div>
            <h3>{mco.data.shortName}</h3>
            <p>Verify {mco.data.shortName}'s dual-diagnosis coverage and what's covered.</p>
            <span class="silo-card-arrow">View plan →</span>
          </a>
        ))}
      </div>

      <InsuranceDisclaimer variant="pre-opening" />
    </div>
  </section>

  <section class="silo-section is-dust">
    <div class="silo-container silo-narrow">
      <div class="silo-section-label">Our approach</div>
      <h2>Integrated dual-diagnosis treatment at Golden Grove</h2>
      <p>{m.integratedTreatmentApproach}</p>

      {m.recommendedTherapies.length > 0 && (
        <>
          <h3>Therapies we use</h3>
          <p>
            {m.recommendedTherapies.map((t, i) => (
              <>
                {i > 0 && ", "}
                <span class="silo-pill">{t.replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase())}</span>
              </>
            ))}
          </p>
        </>
      )}
    </div>
  </section>

  <Cta heading={`Discuss integrated treatment with our admissions team`} />

  <section class="silo-section is-light">
    <div class="silo-container">
      <div class="silo-section-label">Other co-occurring conditions</div>
      <h2>We treat addiction alongside</h2>
      <div class="silo-grid">
        {others.map((o) => (
          <a class="silo-card silo-card-link" href={link(`/mental-health/${o.data.slug}`)}>
            <div class="silo-card-icon"><Icon name="brain" size={28} /></div>
            <div class="silo-card-eyebrow">Dual Diagnosis</div>
            <h3>{o.data.name}</h3>
            <span class="silo-card-arrow">Read more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</div>
