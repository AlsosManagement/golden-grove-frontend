---
import { getCollection, getEntry } from "astro:content";
import Cta from "./Cta.astro";
import InsuranceDisclaimer from "./InsuranceDisclaimer.astro";

export interface Props {
  slug: string;
}

const { slug } = Astro.props as Props;
const entry = await getEntry("levelsOfCare", slug);
if (!entry) throw new Error(`Level of care entry not found: ${slug}`);
const l = entry.data;
const facility = (await getEntry("facility", "golden-grove-recovery"))!.data;
const allLevels = (await getCollection("levelsOfCare"))
  .filter((e) => e.data.slug !== l.slug)
  .sort((a, b) => Number(b.data.asamCode) - Number(a.data.asamCode));

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (p: string) => `${BASE}${p}`;
---

<article class="silo-page">
  <div class="silo-eyebrow">Level of Care · ASAM {l.asamCode}</div>
  <h1>{l.name} in {facility.city}, {facility.stateCode}</h1>
  <p class="silo-lede">{l.description}</p>

  <InsuranceDisclaimer variant="medicaid" />

  <h2>Who benefits from {l.shortName.toLowerCase()}</h2>
  <ul>
    {l.whoBenefits.map((w) => <li>{w}</li>)}
  </ul>

  {l.typicalDay && (
    <>
      <h2>What a typical day looks like</h2>
      <p>{l.typicalDay}</p>
      <p><strong>Typical duration:</strong> {l.typicalDuration}{l.hoursPerWeek ? ` · ${l.hoursPerWeek}` : ""}</p>
    </>
  )}

  {l.imdExclusionNote && (
    <>
      <h2>The IMD exclusion and Kentucky's 1115 waiver</h2>
      <p>{l.imdExclusionNote}</p>
    </>
  )}

  {l.medicaidCoverageSummary && (
    <>
      <h2>Does Kentucky Medicaid cover {l.shortName.toLowerCase()}?</h2>
      <p>{l.medicaidCoverageSummary}</p>
      <p>
        Read more: <a href={link("/medicaid")}>Kentucky Medicaid coverage hub</a> or pick your
        <a href={link("/medicaid")}>Medicaid MCO</a> for plan-specific details.
      </p>
    </>
  )}

  <Cta heading={`Verify your ${l.shortName.toLowerCase()} coverage`} />

  <h2>Other levels of care</h2>
  <ul>
    {allLevels.map((other) => (
      <li>
        <a href={link(`/levels-of-care/${other.data.slug}`)}>
          {other.data.shortName} (ASAM {other.data.asamCode})
        </a> — {other.data.typicalDuration}
      </li>
    ))}
  </ul>

  <p style="margin-top: 24px;">
    Return to the <a href={link("/levels-of-care")}>levels of care overview</a>.
  </p>
</article>
