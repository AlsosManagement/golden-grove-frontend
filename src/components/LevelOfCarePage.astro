---
import { getCollection, getEntry } from "astro:content";
import SiloHero from "./SiloHero.astro";
import Breadcrumbs, { type Crumb } from "./Breadcrumbs.astro";
import Cta from "./Cta.astro";
import InsuranceDisclaimer from "./InsuranceDisclaimer.astro";
import Icon from "./Icon.astro";

export interface Props {
  slug: string;
  trail: Crumb[];
}

const { slug, trail } = Astro.props as Props;
const entry = await getEntry("levelsOfCare", slug);
if (!entry) throw new Error(`Level of care entry not found: ${slug}`);
const l = entry.data;
const facility = (await getEntry("facility", "golden-grove-recovery"))!.data;
const mcos = (await getCollection("mcos")).sort((a, b) => a.data.name.localeCompare(b.data.name));
const allLevels = (await getCollection("levelsOfCare"))
  .filter((e) => e.data.slug !== l.slug)
  .sort((a, b) => Number(b.data.asamCode) - Number(a.data.asamCode));

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (p: string) => `${BASE}${p}`;

const iconBySlug: Record<string, "stethoscope" | "home" | "clock" | "refresh" | "calendar" | "info"> = {
  "medical-detox": "stethoscope",
  "residential-inpatient": "home",
  "partial-hospitalization-php": "clock",
  "intensive-outpatient-iop": "calendar",
  "outpatient": "refresh",
};
---

<div class="silo-body">
  <SiloHero
    eyebrow={`${facility.city}, ${facility.stateCode} · ASAM ${l.asamCode}`}
    title={`${l.name} in ${facility.city}, ${facility.stateCode}`}
    lede={l.description.split(". ")[0] + "."}
  />
  <Breadcrumbs trail={trail} />

  <section class="silo-section is-light">
    <div class="silo-container">
      <div class="silo-section-label">Kentucky Medicaid coverage</div>
      <h2>{l.shortName} is typically covered by Kentucky Medicaid plans</h2>
      <p>
        {l.medicaidCoverageSummary ?? `Kentucky Medicaid plans typically cover ${l.shortName.toLowerCase()} based on medical-necessity determination using clinical criteria.`}
      </p>

      <div class="silo-grid">
        {mcos.map((m) => (
          <a class="silo-card silo-card-link" href={link(`/medicaid/${m.data.slug}`)}>
            <div class="silo-card-icon"><Icon name="shield-check" size={28} /></div>
            <div class="silo-card-eyebrow">Kentucky Medicaid plan</div>
            <h3>{m.data.shortName}</h3>
            <p>See {m.data.shortName}'s coverage detail and what's covered.</p>
            <span class="silo-card-arrow">View plan →</span>
          </a>
        ))}
      </div>

      <InsuranceDisclaimer variant="pre-opening" />
    </div>
  </section>

  <section class="silo-section is-dust">
    <div class="silo-container silo-narrow">
      <div class="silo-section-label">Who this is right for</div>
      <h2>Patients who benefit from {l.shortName.toLowerCase()}</h2>
      <ul>
        {l.whoBenefits.map((w) => <li>{w}</li>)}
      </ul>

      {l.typicalDay && (
        <>
          <h3>Typical day</h3>
          <p>{l.typicalDay}</p>
          <p><strong>Duration:</strong> {l.typicalDuration}{l.hoursPerWeek ? ` · ${l.hoursPerWeek}` : ""}</p>
        </>
      )}

      {l.imdExclusionNote && (
        <>
          <h3>Kentucky's 1115 waiver</h3>
          <p>{l.imdExclusionNote}</p>
        </>
      )}
    </div>
  </section>

  <section class="silo-section is-light">
    <div class="silo-container">
      <div class="silo-section-label">The treatment continuum</div>
      <h2>Other levels of care</h2>
      <div class="silo-grid">
        {allLevels.map((other) => (
          <a class="silo-card silo-card-link" href={link(`/levels-of-care/${other.data.slug}`)}>
            <div class="silo-card-icon"><Icon name={iconBySlug[other.data.slug] ?? "info"} size={28} /></div>
            <div class="silo-card-eyebrow">ASAM {other.data.asamCode}</div>
            <h3>{other.data.shortName}</h3>
            <p>{other.data.typicalDuration}{other.data.hoursPerWeek ? ` · ${other.data.hoursPerWeek}` : ""}</p>
            <span class="silo-card-arrow">Read more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Cta heading={`Discuss ${l.shortName.toLowerCase()} with our admissions team`} />
</div>
